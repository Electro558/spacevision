generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id                   String    @id @default(cuid())
  name                 String?
  email                String    @unique
  emailVerified        DateTime?
  image                String?
  password             String?
  plan                 Plan      @default(FREE)
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?
  dailyGenerations     Int       @default(0)
  lastGenerationDate   DateTime?
  meshCreditsUsed      Int       @default(0) // Monthly mesh generation credits used
  meshCreditsResetDate DateTime? // When credits reset
  status               String    @default("ACTIVE") // ACTIVE | SUSPENDED | BANNED
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  accounts       Account[]
  sessions       Session[]
  savedModels    SavedModel[]
  generationLogs      GenerationLog[]
  auditLogs           AuditLog[]
  generationCaptures  GenerationCapture[]
  generationFeedback  GenerationFeedback[]
  meshGenerations     MeshGeneration[]
}

model SavedModel {
  id          String   @id @default(cuid())
  name        String
  description String?
  sceneData   Json
  thumbnail   String?  @db.Text
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

enum Plan {
  FREE
  PREMIUM
}

model GenerationLog {
  id        String   @id @default(cuid())
  userId    String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model SystemSettings {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  adminId   String
  action    String
  targetId  String?
  metadata  String?
  createdAt DateTime @default(now())

  admin     User     @relation(fields: [adminId], references: [id])

  @@index([adminId])
  @@index([createdAt])
}

// ── Training Data Models ──────────────────────────────────

model TrainingExample {
  id          String   @id @default(cuid())
  prompt      String
  category    String
  difficulty  String   @default("medium") // simple | medium | complex
  description String   @db.Text
  actions     Json     // Array of SceneAction objects
  approved    Boolean  @default(false)
  source      String   @default("handcrafted") // handcrafted | captured | imported
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  datasetItems TrainingDatasetItem[]

  @@index([category])
  @@index([approved])
  @@index([source])
}

model GenerationCapture {
  id                  String   @id @default(cuid())
  userId              String
  prompt              String   @db.Text
  conversationHistory Json?    // Full conversation messages
  toolCalls           Json?    // All tool calls made
  finalSceneState     Json?    // Scene state after generation
  sceneData           Json?    // Objects produced
  modelUsed           String   @default("claude-sonnet-4-20250514")
  consentGiven        Boolean  @default(false)
  createdAt           DateTime @default(now())

  user     User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  feedback GenerationFeedback[]

  @@index([userId])
  @@index([createdAt])
  @@index([consentGiven])
}

model GenerationFeedback {
  id          String   @id @default(cuid())
  captureId   String
  userId      String
  rating      Int      // 1-5 stars
  thumbs      String?  // "up" | "down" | null
  comment     String?
  createdAt   DateTime @default(now())

  capture GenerationCapture @relation(fields: [captureId], references: [id], onDelete: Cascade)
  user    User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([captureId, userId])
  @@index([rating])
}

model TrainingDataset {
  id          String   @id @default(cuid())
  name        String
  description String?
  status      String   @default("draft") // draft | ready | exported | training | completed
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items    TrainingDatasetItem[]
  fineTuneJobs FineTuneJob[]
}

model TrainingDatasetItem {
  id          String   @id @default(cuid())
  datasetId   String
  exampleId   String
  addedAt     DateTime @default(now())

  dataset TrainingDataset @relation(fields: [datasetId], references: [id], onDelete: Cascade)
  example TrainingExample @relation(fields: [exampleId], references: [id], onDelete: Cascade)

  @@unique([datasetId, exampleId])
}

model FineTuneJob {
  id              String   @id @default(cuid())
  datasetId       String
  externalJobId   String?  // Anthropic fine-tune job ID
  modelName       String?  // Resulting model ID
  status          String   @default("pending") // pending | uploading | training | completed | failed
  config          Json?    // Training config (epochs, learning rate, etc.)
  error           String?  @db.Text
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime @default(now())

  dataset TrainingDataset @relation(fields: [datasetId], references: [id])

  @@index([status])
  @@index([datasetId])
}

// ── Mesh Generation Models ──────────────────────────────────

model MeshGeneration {
  id              String   @id @default(cuid())
  userId          String
  prompt          String   @db.Text
  imageUrl        String?  @db.Text // For image-to-3D
  mode            String   @default("text_to_model") // text_to_model | image_to_model
  style           String?  // null = realistic, or: lego, voxel, cartoon, sculpture
  quality         String   @default("standard") // standard | hd | ultra
  tripoTaskId     String?  // External Tripo3D task ID
  status          String   @default("pending") // pending | running | success | failed
  progress        Int      @default(0) // 0-100
  resultUrl       String?  @db.Text // URL to download the model from Tripo
  modelData       Json?    // Stored model URLs per format
  thumbnailUrl    String?  @db.Text // Preview image
  polyCount       Int?
  error           String?  @db.Text
  creditsUsed     Int      @default(1)
  createdAt       DateTime @default(now())
  completedAt     DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}
